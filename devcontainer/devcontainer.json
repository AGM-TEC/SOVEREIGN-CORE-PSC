{
    "name": "SOVEREIGN-CORE-OPERATIONS",
    "image": "mcr.microsoft.com/devcontainers/java:17-bullseye",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": ["fwcd.kotlin", "vscjava.vscode-java-pack"]
        }
    },
    "remoteUser": "vscode",
    "runArgs": ["--cap-add=NET_ADMIN", "--device=/dev/net/tun"],
    "postCreateCommand": "chmod +x deploy.sh && ./deploy.sh"
}
